                    display: "grid", gridTemplateColumns: "1.5fr 1fr 1fr",
                    padding: "14px 20px", gap: 12,
                    borderBottom: i < stage.checkInCadence.length - 1 ? `1px solid ${palette.bgDeep}` : "none",
                    background: i % 2 === 0 ? palette.white : palette.bg,
                  }}>
                    <span style={{ fontSize: 13, fontWeight: 600, color: palette.espresso }}>{c.type}</span>
                    <span style={{ fontSize: 13, color: palette.clay }}>{c.frequency}</span>
                    <span style={{ fontSize: 12, color: palette.mocha }}>{c.notes}</span>
                  </div>
                ))}
              </div>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, padding: "20px 24px" }}>
                <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.slate, marginBottom: 14 }}>
                  FAQ Topics — Know These Cold
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  {stage.faqTopics.map((faq, i) => (
                    <div key={i} style={{
                      background: palette.bgDeep, borderRadius: 6,
                      padding: "10px 14px", fontSize: 12.5,
                      color: palette.espresso, lineHeight: 1.4,
                    }}>
                      {faq}
                    </div>
                  ))}
                </div>
              </div>
            </>)}

            {/* Reactivation — scripts & offboard */}
            {stage.id === "reactivation" && (<>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, padding: "20px 24px" }}>
                <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.clay, marginBottom: 14 }}>
                  Reactivation Outreach — Approach Guide
                </div>
                {stage.reactivationScript.map((s, i) => (
                  <div key={i} style={{ display: "flex", gap: 12, alignItems: "flex-start", marginBottom: 10 }}>
                    <div style={{
                      width: 22, height: 22, minWidth: 22,
                      background: palette.clay, color: palette.white,
                      borderRadius: "50%", display: "flex", alignItems: "center",
                      justifyContent: "center", fontSize: 10, fontWeight: 700,
                    }}>{i + 1}</div>
                    <span style={{ fontSize: 13.5, color: palette.espresso, lineHeight: 1.55, marginTop: 2 }}>{s}</span>
                  </div>
                ))}
              </div>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, padding: "20px 24px" }}>
                <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.blush, marginBottom: 14 }}>
                  Offboard Checklist — If Not Re-engaging
                </div>
                {stage.offboardChecklist.map((item, i) => (
                  <div key={i} style={{ display: "flex", gap: 10, alignItems: "flex-start", marginBottom: 8 }}>
                    <div style={{ width: 16, height: 16, minWidth: 16, border: `1.5px solid ${palette.blush}`, borderRadius: 3, marginTop: 2 }} />
                    <span style={{ fontSize: 13.5, color: palette.espresso, lineHeight: 1.5 }}>{item}</span>
                  </div>
                ))}
              </div>
            </>)}
          </div>
        )}

        {/* RED FLAGS */}
        {section === "flags" && (
          <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
            <p style={{ margin: "0 0 8px", fontSize: 13, color: palette.mocha, lineHeight: 1.6 }}>
              These are signals that something is off. Don't ignore them — flag to KAM or CSO immediately.
            </p>
            {stage.redFlags.map((flag, i) => (
              <div key={i} style={{
                display: "flex", gap: 14, alignItems: "flex-start",
                background: "rgba(196,144,144,0.08)",
                border: "1px solid rgba(196,144,144,0.25)",
                borderLeft: `4px solid ${palette.blush}`,
                borderRadius: 8, padding: "16px 20px",
              }}>
                <span style={{ color: palette.blush, fontSize: 16, marginTop: 1 }}>⚠</span>
                <span style={{ fontSize: 14, color: palette.espresso, lineHeight: 1.55 }}>{flag}</span>
              </div>
            ))}
          </div>
        )}

        {/* Stage nav */}
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 36, paddingTop: 24, borderTop: `1px solid ${palette.line}` }}>
          <button
            onClick={() => { setActive(STAGE_IDS[stageIndex - 1]); setSection("actions"); }}
            disabled={stageIndex === 0}
            style={{
              background: "none", border: `1px solid ${palette.line}`,
              borderRadius: 6, padding: "10px 20px", fontSize: 12,
              color: stageIndex === 0 ? palette.line : palette.mocha,
              cursor: stageIndex === 0 ? "default" : "pointer",
              fontFamily: "inherit",
            }}
          >
            ← Previous stage
          </button>
          <button
            onClick={() => { setActive(STAGE_IDS[stageIndex + 1]); setSection("actions"); }}
            disabled={stageIndex === stages.length - 1}
            style={{
              background: stageIndex === stages.length - 1 ? palette.bgDeep : palette.espresso,
              border: "none", borderRadius: 6, padding: "10px 20px", fontSize: 12,
              color: stageIndex === stages.length - 1 ? palette.line : palette.bg,
              cursor: stageIndex === stages.length - 1 ? "default" : "pointer",
              fontFamily: "inherit",
            }}
          >
            Next stage →
          </button>
        </div>
      </div>
    </div>
  );
}
