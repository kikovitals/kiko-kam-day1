                    borderRadius: 4, padding: "6px 12px", fontSize: 12,
                    border: `1px solid ${palette.line}`,
                  }}>{t}</span>
                ))}
              </div>
            </div>

            <div style={{
              background: palette.white, border: `1px solid ${palette.line}`,
              borderRadius: 8, padding: "20px 24px",
            }}>
              <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.sage, marginBottom: 14 }}>
                ✓ Stage complete when
              </div>
              {stage.outputs.map((o, i) => (
                <div key={i} style={{ display: "flex", gap: 10, alignItems: "flex-start", marginBottom: 8 }}>
                  <span style={{ color: palette.sage, fontSize: 14, marginTop: 1 }}>◆</span>
                  <span style={{ fontSize: 13.5, color: palette.espresso, lineHeight: 1.5 }}>{o}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* DETAIL SECTION — varies by stage */}
        {section === "detail" && (
          <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>

            {/* Intro — qualification */}
            {stage.id === "intro" && (<>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, padding: "20px 24px" }}>
                <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.sage, marginBottom: 14 }}>Qualification criteria — move forward if ALL met</div>
                {stage.qualGates.map((q, i) => (
                  <div key={i} style={{ display: "flex", gap: 10, alignItems: "flex-start", marginBottom: 8 }}>
                    <span style={{ color: palette.sage, marginTop: 2 }}>✓</span>
                    <span style={{ fontSize: 13.5, color: palette.espresso, lineHeight: 1.5 }}>{q}</span>
                  </div>
                ))}
              </div>
            </>)}

            {/* Onboarding — pack & payment */}
            {stage.id === "onboarding" && (<>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, padding: "20px 24px" }}>
                <div style={{ fontSize: 10, letterSpacing: 3, textTransform: "uppercase", color: palette.clay, marginBottom: 14 }}>Onboarding Pack Contents</div>
                {stage.onboardingPack.map((item, i) => (
                  <div key={i} style={{ display: "flex", gap: 10, alignItems: "flex-start", marginBottom: 8 }}>
                    <div style={{ width: 16, height: 16, minWidth: 16, border: `1.5px solid ${palette.clay}`, borderRadius: 3, marginTop: 2 }} />
                    <span style={{ fontSize: 13.5, color: palette.espresso, lineHeight: 1.5 }}>{item}</span>
                  </div>
                ))}
              </div>
              <div style={{ background: palette.white, border: `1px solid ${palette.line}`, borderRadius: 8, overflow: "hidden" }}>
                <div style={{ background: palette.espresso, color: palette.bg, padding: "10px 20px", fontSize: 10, letterSpacing: 3, textTransform: "uppercase" }}>
