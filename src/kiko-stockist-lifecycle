const STAGE_IDS = stages.map(s => s.id);

export default function StockistLifecycle() {
  const [active, setActive] = useState("intro");
  const [section, setSection] = useState("actions");

  const stage = stages.find(s => s.id === active);
  const stageIndex = STAGE_IDS.indexOf(active);

  const sectionTabs = [
    { id: "actions", label: "Actions" },
    { id: "tools", label: "Tools & Outputs" },
    { id: "detail", label: stage?.id === "onboarding" ? "Pack & Payment" : stage?.id === "launch" ? "Merchandising" : stage?.id === "support" ? "Cadence & FAQs" : stage?.id === "reactivation" ? "Scripts & Offboard" : "Qualification" },
    { id: "flags", label: "Red Flags" },
  ];

  return (
    <div style={{
      fontFamily: "'Garamond', 'Georgia', serif",
      background: palette.bg,
      minHeight: "100vh",
      color: palette.ink,
    }}>
      {/* Header */}
      <div style={{
        background: palette.espresso,
        color: palette.bg,
        padding: "36px 48px 32px",
        position: "relative",
        overflow: "hidden",
