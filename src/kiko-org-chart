                      <Avatar name={mgr.name} color={mgr.color} size={26} type={mgr.type} />
                      <div>
                        <div style={{ fontSize: 12, fontWeight: 700, color: c.espresso }}>{mgr.name}</div>
                        <div style={{ fontSize: 10, color: c.mocha }}>{mgr.role}</div>
                      </div>
                    </div>
                  </Sec>
                ) : null;
              })()}

              <Sec label="Owns">
                {sel.owns.map((o, i) => (
                  <div key={i} style={{ display: "flex", gap: 8, marginBottom: 5, alignItems: "flex-start" }}>
                    <span style={{ color: c.clay, fontSize: 9, marginTop: 3, flexShrink: 0 }}>◆</span>
                    <span style={{ fontSize: 11.5, color: c.espresso, lineHeight: 1.5 }}>{o}</span>
                  </div>
                ))}
              </Sec>

              <Sec label="Escalate To">
                <div style={{ fontSize: 11.5, color: c.mocha, lineHeight: 1.5 }}>{sel.escalateTo}</div>
              </Sec>

              {sel.note ? (
                <div style={{
                  background: c.bg, border: `1px solid ${c.line}`,
                  borderLeft: `3px solid ${sel.type === "placeholder" ? c.placeholder : sel.color}`,
                  borderRadius: 6, padding: "10px 12px",
                  fontSize: 11, color: c.mocha, lineHeight: 1.6, fontStyle: "italic",
                }}>
                  {sel.note}
                </div>
              ) : null}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

function DirCard({ person, onSelect }) {
  const isPlaceholder = person.type === "placeholder";
  return (
    <button onClick={() => onSelect(person.id)} style={{
      background: c.white,
      border: `1px ${isPlaceholder ? "dashed" : "solid"} ${isPlaceholder ? c.placeholder : c.line}`,
      borderLeft: `4px ${isPlaceholder ? "dashed" : "solid"} ${person.color}`,
      borderRadius: 8, padding: "14px 16px",
      display: "flex", gap: 12, alignItems: "center",
      cursor: "pointer", fontFamily: "inherit", textAlign: "left", width: "100%",
    }}>
      <Avatar name={person.name} color={person.color} size={38} type={person.type} />
      <div>
        <div style={{ fontSize: 13, fontWeight: 700, color: isPlaceholder ? c.placeholder : c.espresso }}>{person.name}</div>
        <div style={{ fontSize: 11, color: c.mocha, marginTop: 2, lineHeight: 1.3 }}>{person.role}</div>
        <div style={{ display: "flex", gap: 5, marginTop: 4 }}>
          {person.type === "external" && <span style={{ fontSize: 8, color: c.ext, letterSpacing: 0.5, textTransform: "uppercase" }}>External</span>}
          {isPlaceholder && <span style={{ fontSize: 8, color: c.placeholder, letterSpacing: 0.5, textTransform: "uppercase" }}>Role to fill</span>}
        </div>
      </div>
    </button>
  );
}
