          Stockist Lifecycle System
        </h1>
        <p style={{ margin: 0, fontSize: 13, color: "rgba(245,240,232,0.55)", maxWidth: 520 }}>
          The complete framework from first contact to long-term account management. Every stage, every action, every owner.
        </p>
      </div>

      {/* Pipeline strip */}
      <div style={{
        background: palette.espresso,
        padding: "0 48px 24px",
        display: "flex",
        gap: 0,
        alignItems: "stretch",
      }}>
        {stages.map((s, i) => {
          const isActive = active === s.id;
          const isPast = stageIndex > i;
          return (
            <div key={s.id} style={{ display: "flex", alignItems: "center", flex: 1 }}>
              <button
                onClick={() => { setActive(s.id); setSection("actions"); }}
                style={{
                  flex: 1,
                  background: isActive ? s.color : isPast ? "rgba(255,255,255,0.06)" : "rgba(255,255,255,0.03)",
                  border: isActive ? `none` : "1px solid rgba(255,255,255,0.08)",
                  borderRadius: 6,
                  padding: "12px 14px",
                  cursor: "pointer",
                  fontFamily: "inherit",
                  textAlign: "left",
                  transition: "all 0.2s",
                }}
              >
                <div style={{ fontSize: 10, color: isActive ? "rgba(255,255,255,0.7)" : "rgba(255,255,255,0.25)", marginBottom: 4, letterSpacing: 2 }}>
