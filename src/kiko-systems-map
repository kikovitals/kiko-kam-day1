                          border: `1px solid ${b.clay}`,
                          borderRadius: "50%",
                          display: "flex", alignItems: "center", justifyContent: "center",
                          fontSize: 11, fontWeight: 700, color: b.clay,
                        }}>
                          {i + 1}
                        </div>
                        <span style={{ fontSize: 13.5, color: "rgba(250,247,242,0.8)", lineHeight: 1.6 }}>{wf}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
