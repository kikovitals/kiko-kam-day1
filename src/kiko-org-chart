function Avatar({ name, color, size = 40, type }) {
  const isPlaceholder = type === "placeholder";
  const initials = isPlaceholder ? "?" : name.replace(/[^a-zA-Z ]/g, "").split(" ").map(w => w[0]).join("").slice(0, 2).toUpperCase();
  return (
    <div style={{
      width: size, height: size, minWidth: size, borderRadius: "50%",
      background: isPlaceholder ? "transparent" : color,
      border: isPlaceholder ? `2px dashed ${c.placeholder}` : type === "external" ? `2px dashed rgba(255,255,255,0.4)` : "none",
      display: "flex", alignItems: "center", justifyContent: "center",
      fontSize: size * 0.3, fontWeight: 700,
      color: isPlaceholder ? c.placeholder : c.white,
      flexShrink: 0, position: "relative",
    }}>
      {initials}
      {type === "external" && !isPlaceholder && (
        <div style={{
          position: "absolute", bottom: -1, right: -1,
          width: Math.max(10, size * 0.25), height: Math.max(10, size * 0.25),
          borderRadius: "50%", background: c.ext,
          border: `2px solid ${c.bg}`,
          fontSize: 6, color: c.white,
          display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 900,
        }}>E</div>
      )}
    </div>
  );
}

// A single card node
function Card({ person, onSelect, selected, size = "md" }) {
  const isSelected = selected === person.id;
  const isPlaceholder = person.type === "placeholder";
  const sm = size === "sm";

  return (
    <button onClick={() => onSelect(person.id)} style={{
      background: isSelected ? (isPlaceholder ? c.sand : person.color) : c.white,
      border: `2px solid ${isSelected ? (isPlaceholder ? c.placeholder : person.color) : isPlaceholder ? c.placeholder : c.line}`,
      borderStyle: isPlaceholder ? "dashed" : "solid",
      borderRadius: 10,
      padding: sm ? "8px 10px" : "12px 14px",
      cursor: "pointer", fontFamily: "inherit",
      width: sm ? 108 : 128,
      boxShadow: isSelected && !isPlaceholder ? `0 4px 16px ${person.color}35` : "0 1px 3px rgba(0,0,0,0.06)",
      transition: "all 0.15s", flexShrink: 0,
    }}>
      <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: sm ? 5 : 7 }}>
        <Avatar
          name={person.name}
          color={isSelected && !isPlaceholder ? "rgba(255,255,255,0.25)" : person.color}
          size={sm ? 30 : 38}
          type={person.type}
        />
        <div style={{ textAlign: "center" }}>
          <div style={{
            fontSize: sm ? 10 : 11, fontWeight: 700, lineHeight: 1.2,
            color: isSelected ? (isPlaceholder ? c.mocha : c.white) : isPlaceholder ? c.placeholder : c.espresso,
          }}>
            {person.name}
          </div>
          <div style={{
            fontSize: sm ? 8 : 9, lineHeight: 1.3, marginTop: 2,
            color: isSelected ? (isPlaceholder ? c.mocha : "rgba(255,255,255,0.7)") : isPlaceholder ? c.placeholder : c.mocha,
          }}>
            {person.role}
          </div>
          {person.type === "external" && (
            <div style={{ fontSize: 7, color: isSelected ? "rgba(255,255,255,0.55)" : c.ext, marginTop: 3, letterSpacing: 0.5, textTransform: "uppercase" }}>Ext</div>
          )}
        </div>
      </div>
    </button>
  );
}

// Vertical connector line
function VConn({ h = 20, dashed = false }) {
  return (
    <div style={{
      width: 0, height: h, margin: "0 auto",
      borderLeft: `2px ${dashed ? "dashed" : "solid"} ${c.line}`,
    }} />
  );
}

// Horizontal bracket connecting multiple children
function HBracket({ count, itemWidth, gap }) {
  if (count <= 1) return <VConn h={20} />;
  const totalW = count * itemWidth + (count - 1) * gap;
  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center", width: totalW }}>
      <VConn h={14} />
      <div style={{ width: totalW - itemWidth, height: 2, background: c.line, position: "relative" }}>
        {/* The horizontal bar spans from centre of first child to centre of last child */}
      </div>
    </div>
  );
}

// Renders a parent + its children with proper connectors
function TreeBlock({ node, onSelect, selected, depth = 0 }) {
  const children = node.children || [];
  const cardW = depth >= 2 ? 108 : 128;
  const gap = 12;

  return (
    <div style={{ display: "flex", flexDirection: "column", alignItems: "center" }}>
      {/* Optional badge above card */}
      {node.badge && (
        <div style={{
          fontSize: 8, letterSpacing: 1.5, textTransform: "uppercase",
          color: node.type === "placeholder" ? c.placeholder : node.color,
          border: `1px solid ${node.type === "placeholder" ? c.placeholder : node.color}`,
          borderRadius: 3, padding: "2px 8px", marginBottom: 4,
        }}>
          {node.badge}
        </div>
      )}

      <Card person={node} onSelect={onSelect} selected={selected} size={depth >= 2 ? "sm" : "md"} />

      {children.length > 0 && (
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center" }}>
          {/* Stem down from parent */}
          <VConn h={16} />

          {children.length === 1 ? (
            // Single child — straight line
            <TreeBlock node={children[0]} onSelect={onSelect} selected={selected} depth={depth + 1} />
          ) : (
            // Multiple children — bracket
            <div style={{ display: "flex", flexDirection: "column", alignItems: "center" }}>
              {/* Horizontal bar */}
              {(() => {
                const totalW = children.length * cardW + (children.length - 1) * gap;
                const halfW = totalW / 2;
                return (
                  <div style={{ position: "relative", width: totalW, height: 0 }}>
                    <div style={{
                      position: "absolute",
                      top: 0, left: cardW / 2, right: cardW / 2,
                      height: 2, background: c.line,
                    }} />
                  </div>
                );
              })()}

              {/* Children row with drop lines */}
              <div style={{ display: "flex", gap, alignItems: "flex-start" }}>
                {children.map((child) => (
                  <div key={child.id} style={{ display: "flex", flexDirection: "column", alignItems: "center" }}>
                    <VConn h={18} />
                    <TreeBlock node={child} onSelect={onSelect} selected={selected} depth={depth + 1} />
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

// Detail panel section
function Sec({ label, children }) {
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ fontSize: 8, letterSpacing: 3, textTransform: "uppercase", color: c.clay, marginBottom: 8 }}>{label}</div>
      {children}
    </div>
  );
}

